# 1) Get TG_API_ID and TG_API_HASH from https://my.telegram.org/apps
TG_API_ID=123456
TG_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) Create bot via @BotFather and paste token
BOT_TOKEN=123456789:AA...your_token_here
TZ=Europe/Kyiv

# Optional retention/cleanup controls
DB_RETENTION_DAYS=60
DB_CLEANUP_EVERY_MIN=60

# Optional digest robustness/dedup tuning
DIGEST_HOURLY_WINDOW_MIN=95
DIGEST_DAILY_WINDOW_HOURS=26
SIMHASH_MAX_HAMMING=8
TEXT_DEDUP_RATIO=0.88
TEXT_DEDUP_MIN_LEN=80
EMBEDDING_CLUSTER_THRESHOLD=0.84
QUIET_CATCHUP_MAX_HOURS=12

# Optional: number of media preview links sent after each digest
DIGEST_MEDIA_PREVIEW_MAX=3
